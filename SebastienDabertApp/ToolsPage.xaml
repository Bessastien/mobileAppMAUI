<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SebastienDabertApp.ViewModels"
             xmlns:models="clr-namespace:SebastienDabertApp.Models"
             x:Class="SebastienDabertApp.ToolsPage"
             x:DataType="viewmodels:ToolsViewModel"
             Title="Outils"
             BackgroundColor="#1B1B2F">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,40" Spacing="28">

            <!-- En-tête -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Outils du skieur"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="#E8E880" HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="1" Color="#E8E880" Opacity="0.2" Margin="30,6,30,0" />
            </VerticalStackLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- Fonctionnalite 1 : Convertisseur d'altitude               -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border BackgroundColor="#37465E"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#3A3A5A"
                    StrokeThickness="1"
                    Padding="20,18">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Convertisseur d'altitude"
                           FontSize="17" FontAttributes="Bold" TextColor="#E8E880" />

                    <Label Text="Saisir une altitude en metres :"
                           FontSize="13" TextColor="#AAAAAA" />

                    <!-- Champ de saisie -->
                    <Border BackgroundColor="#1B1B2F"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#3A3A5A" StrokeThickness="1"
                            Padding="4,0">
                        <Entry Placeholder="ex : 3842"
                               PlaceholderColor="#555577"
                               TextColor="White"
                               Text="{Binding AltitudeMetersText}"
                               Keyboard="Numeric"
                               FontSize="16" />
                    </Border>

                    <!-- Résultat en pieds -->
                    <Border BackgroundColor="#1B1B2F"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#E8E880" StrokeThickness="1"
                            Padding="16,14"
                            IsVisible="{Binding HasAltitude}">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Equivalent en pieds"
                                       FontSize="11" TextColor="#888888" />
                                <Label Text="{Binding AltitudeFeet}"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="#E8E880" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="x 3.28084"
                                       FontSize="11" TextColor="#555577"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding AltitudeMetersText, StringFormat='{0} m'}"
                                       FontSize="14" TextColor="#CCCCCC"
                                       HorizontalTextAlignment="End" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Placeholder résultat vide -->
                    <Border BackgroundColor="#1B1B2F"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#3A3A5A" StrokeThickness="1"
                            Padding="16,12">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding HasAltitude}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="Entrez une valeur pour voir la conversion"
                               FontSize="13" TextColor="#555577"
                               HorizontalTextAlignment="Center" />
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- Fonctionnalite 2 : Checklist de depart                    -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Border BackgroundColor="#37465E"
                    StrokeShape="RoundRectangle 14"
                    Stroke="#3A3A5A"
                    StrokeThickness="1"
                    Padding="20,18">
                <VerticalStackLayout Spacing="14">

                    <!-- Titre + progression -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Checklist de depart"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="#E8E880"
                               VerticalTextAlignment="Center" />
                        <Border Grid.Column="1"
                                BackgroundColor="#1B1B2F"
                                StrokeShape="RoundRectangle 8"
                                Stroke="#E8E880" StrokeThickness="1"
                                Padding="10,6">
                            <Label Text="{Binding ChecklistProgress}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#E8E880" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E8E880" Opacity="0.1" />

                    <!-- Liste des items -->
                    <VerticalStackLayout Spacing="2"
                                         BindableLayout.ItemsSource="{Binding Checklist}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:ChecklistItem">
                                <Border BackgroundColor="#243040"
                                        StrokeShape="RoundRectangle 8"
                                        Stroke="Transparent"
                                        Padding="12,10"
                                        Margin="0,2">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsChecked}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#1E3A2E" />
                                            <Setter Property="Stroke" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsChecked}"
                                                  CheckedChanged="OnCheckBoxCheckedChanged"
                                                  Color="#E8E880"
                                                  VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="15"
                                               VerticalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsChecked}" Value="True">
                                                    <Setter Property="TextColor" Value="#4CAF50" />
                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsChecked}" Value="False">
                                                    <Setter Property="TextColor" Value="White" />
                                                    <Setter Property="TextDecorations" Value="None" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E8E880" Opacity="0.1" />

                    <!-- Bouton reset -->
                    <Button Text="Tout decocher"
                            Command="{Binding ResetChecklistCommand}"
                            BackgroundColor="#1B1B2F"
                            TextColor="#E8E880"
                            FontSize="13"
                            CornerRadius="8"
                            HeightRequest="40"
                            BorderColor="#3A3A5A"
                            BorderWidth="1" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

