<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SebastienDabertApp.ViewModels"
             xmlns:models="clr-namespace:SebastienDabertApp.Models"
             x:Class="SebastienDabertApp.ResortsPage"
             x:DataType="viewmodels:ResortsViewModel"
             Title="Stations"
             BackgroundColor="#1B1B2F">

    <Grid RowDefinitions="Auto,*">

        <!-- En-tête -->
        <VerticalStackLayout Grid.Row="0" Padding="20,20,20,8" Spacing="6">
            <Label Text="Nos Stations"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#E8E880"
                   HorizontalTextAlignment="Center" />
            <Label Text="Températures en direct via Open-Meteo"
                   FontSize="13"
                   TextColor="#888888"
                   HorizontalTextAlignment="Center" />
            <BoxView HeightRequest="1"
                     Color="#E8E880"
                     Opacity="0.2"
                     Margin="30,8,30,0" />
        </VerticalStackLayout>

        <!-- Spinner de chargement -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#E8E880"
                           HeightRequest="40"
                           WidthRequest="40"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Liste des stations -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Resorts}"
                        SelectionMode="None"
                        Margin="16,8,16,0">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SkiResort">

                    <!-- Carte station compacte -->
                    <Border BackgroundColor="#37465E"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#3A3A5A"
                            StrokeThickness="1"
                            Padding="16,14"
                            Shadow="{Shadow Brush='#000000', Offset='0,4', Radius=12, Opacity=0.4}">

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="6">

                            <!-- Nom de la station -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalTextAlignment="Center" />

                            <!-- Badge température -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    Grid.RowSpan="2"
                                    BackgroundColor="#1B1B2F"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="#E8E880"
                                    StrokeThickness="1"
                                    Padding="10,8"
                                    VerticalOptions="Center">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="🌡️"
                                           FontSize="16"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding CurrentTemperature}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#E8E880"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Latitude -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                <Label Text="📍"
                                       FontSize="12"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{Binding Latitude, StringFormat='{0:F4}°N'}"
                                       FontSize="13"
                                       TextColor="#888888"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>

                        </Grid>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>


        </CollectionView>

    </Grid>

</ContentPage>



