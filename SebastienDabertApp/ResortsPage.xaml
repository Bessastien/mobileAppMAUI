<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SebastienDabertApp.ViewModels"
             xmlns:models="clr-namespace:SebastienDabertApp.Models"
             x:Class="SebastienDabertApp.ResortsPage"
             x:DataType="viewmodels:ResortsViewModel"
             Title="Stations"
             BackgroundColor="#1B1B2F">

    <Grid RowDefinitions="Auto,*">

        <!-- En-tête -->
        <VerticalStackLayout Grid.Row="0" Padding="20,20,20,8" Spacing="6">
            <Label Text="Mes Stations"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#E8E880"
                   HorizontalTextAlignment="Center" />
            <Label Text="Températures en direct via Open-Meteo"
                   FontSize="13"
                   TextColor="#888888"
                   HorizontalTextAlignment="Center" />
            <BoxView HeightRequest="1"
                     Color="#E8E880"
                     Opacity="0.2"
                     Margin="30,8,30,0" />
        </VerticalStackLayout>

        <!-- Spinner de chargement -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#E8E880"
                           HeightRequest="40"
                           WidthRequest="40"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Liste des stations -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Resorts}"
                        SelectionMode="None"
                        Margin="12,0">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SkiResort">

                    <Border BackgroundColor="#2A2A4A"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#3A3A5A"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="0,6">

                        <!-- Remplacement par une Grid à 3 colonnes pour inclure l'image -->
                        <Grid ColumnDefinitions="100,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="4">

                            <!-- Image de la station -->
                            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    HeightRequest="70"
                                    WidthRequest="100"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center">
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="70"
                                       WidthRequest="100" />
                            </Border>

                            <!-- Nom de la station -->
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Name}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalTextAlignment="End"
                                   LineBreakMode="TailTruncation" />

                            <!-- Latitude -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4" VerticalOptions="Start">
                                <Label Text="📍" FontSize="12" TextColor="#888888" VerticalTextAlignment="Center" />
                                <Label TextColor="#AAAAAA" FontSize="12" VerticalTextAlignment="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Latitude, StringFormat='{0:F2}'}" />
                                            <Span Text=", " />
                                            <Span Text="{Binding Longitude, StringFormat='{0:F2}'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <!-- Badge température -->
                            <Border Grid.Row="0" Grid.Column="2"
                                    Grid.RowSpan="2"
                                    BackgroundColor="#1B1B2F"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="#E8E880"
                                    StrokeThickness="1"
                                    Padding="10,8"
                                    VerticalOptions="Center">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="🌡️"
                                           FontSize="16"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding CurrentTemperature}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#E8E880"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                        <!-- GestureRecognizer pour la navigation -->
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ResortsViewModel}}, Path=GoToDetailCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>


        </CollectionView>

    </Grid>

</ContentPage>



