<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SebastienDabertApp.ViewModels"
             x:Class="SebastienDabertApp.ResortDetailPage"
             x:DataType="viewmodels:ResortDetailViewModel"
             Title="{Binding SelectedResort.Name}"
             BackgroundColor="#1B1B2F">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Image en grand -->
            <Grid HeightRequest="280">
                <Image Source="{Binding SelectedResort.ImageUrl}"
                       Aspect="AspectFill"
                       HeightRequest="280" />

                <!-- Dégradé sombre en bas de l'image -->
                <BoxView VerticalOptions="End"
                         HeightRequest="100">
                    <BoxView.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#1B1B2F" Offset="1" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Nom de la station sur l'image -->
                <Label Text="{Binding SelectedResort.Name}"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="End"
                       Margin="20,0,20,16"
                       Shadow="{Shadow Brush='#000000', Offset='1,2', Radius=6, Opacity=0.8}" />
            </Grid>

            <!-- Contenu détaillé -->
            <VerticalStackLayout Padding="20,24,20,32" Spacing="20">

                <!-- Badge température -->
                <Border BackgroundColor="#37465E"
                        StrokeShape="RoundRectangle 12"
                        Stroke="#E8E880"
                        StrokeThickness="1"
                        Padding="16,12"
                        HorizontalOptions="Start">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🌡️" FontSize="22" VerticalTextAlignment="Center" />
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="Température actuelle"
                                   FontSize="12"
                                   TextColor="#888888" />
                            <Label Text="{Binding SelectedResort.CurrentTemperature}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#E8E880" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Séparateur -->
                <BoxView HeightRequest="1"
                         Color="#E8E880"
                         Opacity="0.15" />

                <!-- Description -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="À propos de la station"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#E8E880" />
                    <Label Text="{Binding SelectedResort.Description}"
                           FontSize="15"
                           TextColor="#CCCCCC"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>

                <!-- Séparateur -->
                <BoxView HeightRequest="1"
                         Color="#E8E880"
                         Opacity="0.15" />

                <!-- Coordonnées géographiques -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Localisation *"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#E8E880" />
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍" FontSize="14" VerticalTextAlignment="Center" />
                        <Label FontSize="14" TextColor="#AAAAAA" VerticalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding SelectedResort.Latitude, StringFormat='Lat : {0:F4}°N'}" />
                                    <Span Text="   " />
                                    <Span Text="{Binding SelectedResort.Longitude, StringFormat='Lon : {0:F4}°E'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

