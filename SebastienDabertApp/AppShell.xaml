<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SebastienDabertApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SebastienDabertApp"
    Title="SebastienDabertApp"
    Shell.TabBarBackgroundColor="#1B1B2F"
    Shell.TabBarUnselectedColor="#888888"
    Shell.TabBarTitleColor="#00E5FF"
    Shell.TabBarForegroundColor="#00E5FF">

    <TabBar>
        <ShellContent
            Title="Accueil"
            Icon="icon_home.png"
            ContentTemplate="{DataTemplate local:HomePage}"
            Route="HomePage" />

        <ShellContent
            Title="Stations"
            Icon="icon_stations.png"
            ContentTemplate="{DataTemplate local:StationsPage}"
            Route="StationsPage" />

        <ShellContent
            Title="Ajouter"
            Icon="icon_add.png"
            ContentTemplate="{DataTemplate local:AddPage}"
            Route="AddPage" />

        <ShellContent
            Title="Outils"
            Icon="icon_tools.png"
            ContentTemplate="{DataTemplate local:ToolsPage}"
            Route="ToolsPage" />
    </TabBar>

</Shell>
