<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SebastienDabertApp.HomePage"
             Title="Accueil"
             BackgroundColor="#1B1B2F">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Logo -->
            <Image Source="logo_ski.svg"
                   HeightRequest="80"
                   Aspect="AspectFit"
                   Margin="0,10,0,0" />

            <!-- Grand titre -->
            <Label Text="Bienvenue sur SkiApp"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#00E5FF"
                   HorizontalTextAlignment="Center" />

            <!-- Sous-titre -->
            <Label Text="Prépare ta prochaine descente"
                   FontSize="18"
                   TextColor="#CCCCCC"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10" />

            <!-- Séparateur -->
            <BoxView HeightRequest="1"
                     Color="#00E5FF"
                     Opacity="0.3"
                     Margin="40,0" />

            <!-- Deux images de ski côte à côte -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,10">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="0"
                        BackgroundColor="#2A2A4A"
                        Stroke="Transparent"
                        StrokeThickness="0">
                    <Image Source="ski_pose.png"
                           Aspect="AspectFill"
                           HeightRequest="180" />
                </Border>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="0"
                        BackgroundColor="#2A2A4A"
                        Stroke="Transparent"
                        StrokeThickness="0">
                    <Image Source="ski_mountain.png"
                           Aspect="AspectFill"
                           HeightRequest="180" />
                </Border>
            </Grid>

            <!-- Séparateur -->
            <BoxView HeightRequest="1"
                     Color="#00E5FF"
                     Opacity="0.3"
                     Margin="40,0" />

            <!-- Titre section CarouselView -->
            <Label Text="Le saviez-vous ?"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalTextAlignment="Center"
                   Margin="0,5,0,0" />

            <!-- CarouselView de citations / marques -->
            <CarouselView x:Name="CarouselQuotes"
                          HeightRequest="200"
                          IndicatorView="CarouselIndicator"
                          Loop="True"
                          PeekAreaInsets="20">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#2A2A4A"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#00E5FF"
                                StrokeThickness="1"
                                Padding="20"
                                Margin="8">
                            <VerticalStackLayout VerticalOptions="Center"
                                                 Spacing="12">
                                <Label Text="{Binding Quote}"
                                       FontSize="16"
                                       TextColor="White"
                                       FontAttributes="Italic"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding Author}"
                                       FontSize="14"
                                       TextColor="#00E5FF"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Brand}"
                                       FontSize="12"
                                       TextColor="#888888"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <!-- Indicateur de position du carousel -->
            <IndicatorView x:Name="CarouselIndicator"
                           IndicatorColor="#555555"
                           SelectedIndicatorColor="#00E5FF"
                           IndicatorSize="8"
                           HorizontalOptions="Center"
                           Margin="0,0,0,20" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>





