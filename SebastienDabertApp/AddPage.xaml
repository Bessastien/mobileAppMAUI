<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SebastienDabertApp.ViewModels"
             x:Class="SebastienDabertApp.AddPage"
             x:DataType="viewmodels:AddResortViewModel"
             Title="Ajouter une station"
             BackgroundColor="#1B1B2F">

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,40" Spacing="24">

            <!-- ── En-tête ── -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Nouvelle station"
                       FontSize="28" FontAttributes="Bold"
                       TextColor="#E8E880" HorizontalTextAlignment="Center" />
                <Label Text="Remplissez les informations ci-dessous"
                       FontSize="13" TextColor="#888888" HorizontalTextAlignment="Center" />
                <BoxView HeightRequest="1" Color="#E8E880" Opacity="0.2" Margin="30,8,30,0" />
            </VerticalStackLayout>

            <!-- ── Nom ── -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Nom de la station *" FontSize="14" FontAttributes="Bold" TextColor="#E8E880" />
                <Border BackgroundColor="#37465E" StrokeShape="RoundRectangle 10"
                        Stroke="#3A3A5A" StrokeThickness="1" Padding="4,0">
                    <Entry Placeholder="ex : Tignes, Méribel…" PlaceholderColor="#555577"
                           TextColor="White" Text="{Binding Name}" ReturnType="Next" FontSize="15" />
                </Border>
            </VerticalStackLayout>

            <!-- ── Description ── -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Description" FontSize="14" FontAttributes="Bold" TextColor="#E8E880" />
                <Border BackgroundColor="#37465E" StrokeShape="RoundRectangle 10"
                        Stroke="#3A3A5A" StrokeThickness="1" Padding="4,4">
                    <Editor Placeholder="Décrivez la station (situation, spécialité…)"
                            PlaceholderColor="#555577" TextColor="White"
                            Text="{Binding Description}" AutoSize="TextChanges"
                            MinimumHeightRequest="100" FontSize="15" />
                </Border>
            </VerticalStackLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- Section Image                                              -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Photo de la station" FontSize="14" FontAttributes="Bold" TextColor="#E8E880" />

                <!-- Aperçu si image choisie -->
                <Border StrokeShape="RoundRectangle 12" Stroke="#3A3A5A" StrokeThickness="1"
                        HeightRequest="180" IsVisible="{Binding HasImage}" BackgroundColor="#37465E">
                    <Image Source="{Binding LocalImagePath}" Aspect="AspectFill" />
                </Border>

                <!-- Placeholder si pas d'image -->
                <Border StrokeShape="RoundRectangle 12" Stroke="#3A3A5A" StrokeThickness="1"
                        HeightRequest="120" BackgroundColor="#37465E">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding HasImage}" Value="True">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                        <Label Text="Aucune photo selectionnee"
                               FontSize="13" TextColor="#666688" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Choisir depuis la galerie"
                        Command="{Binding PickImageCommand}"
                        BackgroundColor="#37465E" TextColor="#E8E880"
                        FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="48" />
            </VerticalStackLayout>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- Section Localisation                                       -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Localisation" FontSize="14" FontAttributes="Bold" TextColor="#E8E880" />

                <!-- Toggle 2 modes -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">

                    <!-- GPS -->
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="1.5" Padding="0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsGpsMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="#E8E880" />
                                <Setter Property="Stroke" Value="#E8E880" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsGpsMode}" Value="False">
                                <Setter Property="BackgroundColor" Value="#37465E" />
                                <Setter Property="Stroke" Value="#3A3A5A" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Button Text="Ma position" Command="{Binding SelectGpsModeCommand}"
                                BackgroundColor="Transparent" FontSize="13" FontAttributes="Bold" HeightRequest="44">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsGpsMode}" Value="True">
                                    <Setter Property="TextColor" Value="#1B1B2F" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsGpsMode}" Value="False">
                                    <Setter Property="TextColor" Value="#AAAAAA" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Border>

                    <!-- Manuel -->
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 10" StrokeThickness="1.5" Padding="0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsManualMode}" Value="True">
                                <Setter Property="BackgroundColor" Value="#E8E880" />
                                <Setter Property="Stroke" Value="#E8E880" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsManualMode}" Value="False">
                                <Setter Property="BackgroundColor" Value="#37465E" />
                                <Setter Property="Stroke" Value="#3A3A5A" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Button Text="Saisie manuelle" Command="{Binding SelectManualModeCommand}"
                                BackgroundColor="Transparent" FontSize="13" FontAttributes="Bold" HeightRequest="44">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsManualMode}" Value="True">
                                    <Setter Property="TextColor" Value="#1B1B2F" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding IsManualMode}" Value="False">
                                    <Setter Property="TextColor" Value="#AAAAAA" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Border>
                </Grid>

                <!-- ── Mode GPS ── -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsGpsMode}">
                    <Button Text="Utiliser ma position actuelle"
                            Command="{Binding UseMyLocationCommand}"
                            BackgroundColor="#37465E" TextColor="#E8E880"
                            FontSize="14" FontAttributes="Bold" CornerRadius="10" HeightRequest="48">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsLocating}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="Opacity" Value="0.5" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsLocating}" Value="False">
                                <Setter Property="IsEnabled" Value="True" />
                                <Setter Property="Opacity" Value="1" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <ActivityIndicator IsRunning="{Binding IsLocating}" IsVisible="{Binding IsLocating}"
                                       Color="#E8E880" HeightRequest="28" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- ── Mode Manuel ── -->
                <VerticalStackLayout Spacing="10" IsVisible="{Binding IsManualMode}">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Latitude" FontSize="12" TextColor="#AAAAAA" />
                            <Border BackgroundColor="#37465E" StrokeShape="RoundRectangle 8"
                                    Stroke="#3A3A5A" StrokeThickness="1" Padding="4,0">
                                <Entry Placeholder="45.9237" PlaceholderColor="#555577"
                                       TextColor="White" Text="{Binding LatitudeText}"
                                       Keyboard="Numeric" FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Longitude" FontSize="12" TextColor="#AAAAAA" />
                            <Border BackgroundColor="#37465E" StrokeShape="RoundRectangle 8"
                                    Stroke="#3A3A5A" StrokeThickness="1" Padding="4,0">
                                <Entry Placeholder="6.8694" PlaceholderColor="#555577"
                                       TextColor="White" Text="{Binding LongitudeText}"
                                       Keyboard="Numeric" FontSize="14" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="Previsualiser la temperature"
                            Command="{Binding PreviewTemperatureCommand}"
                            BackgroundColor="#37465E" TextColor="#E8E880"
                            FontSize="13" CornerRadius="8" HeightRequest="42" />
                </VerticalStackLayout>

                <!-- Statut localisation -->
                <Border BackgroundColor="#243040" StrokeShape="RoundRectangle 8"
                        Stroke="#3A3A5A" StrokeThickness="1" Padding="12,10" IsVisible="False">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding LocationStatus}" Value="">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{Binding LocationStatus}" TextColor="#CCCCCC" FontSize="13" />
                </Border>

                <!-- Prévisualisation température -->
                <Border BackgroundColor="#1B2E3A" StrokeShape="RoundRectangle 8"
                        Stroke="#E8E880" StrokeThickness="1" Padding="12,10" IsVisible="False">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding TemperaturePreview}" Value="">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsPreviewingTemp}"
                                           IsVisible="{Binding IsPreviewingTemp}"
                                           Color="#E8E880" HeightRequest="20" WidthRequest="20"
                                           VerticalOptions="Center" />
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="Temperature a cet emplacement" FontSize="11" TextColor="#888888" />
                            <Label Text="{Binding TemperaturePreview}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#E8E880" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- Message de succès -->
            <Border BackgroundColor="#1E3A2E" StrokeShape="RoundRectangle 10"
                    Stroke="#4CAF50" StrokeThickness="1" Padding="14,10"
                    IsVisible="{Binding IsSuccess}">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Station ajoutee avec succes !"
                           TextColor="#4CAF50" FontSize="14" FontAttributes="Bold"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Message d'erreur -->
            <Border BackgroundColor="#3A1E1E" StrokeShape="RoundRectangle 10"
                    Stroke="#E53935" StrokeThickness="1" Padding="14,10" IsVisible="False">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding ErrorMessage}" Value="">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Border.Triggers>
                <Label Text="{Binding ErrorMessage}" TextColor="#EF5350" FontSize="13" />
            </Border>

            <!-- Bouton Ajouter -->
            <Button Text="Ajouter la station"
                    Command="{Binding AddResortCommand}"
                    BackgroundColor="#E8E880" TextColor="#1B1B2F"
                    FontAttributes="Bold" FontSize="16" CornerRadius="12" HeightRequest="52"
                    Shadow="{Shadow Brush='#E8E880', Offset='0,4', Radius=10, Opacity=0.3}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

