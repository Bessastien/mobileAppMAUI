<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SebastienDabertApp.TrickPage"
             Title="Trick du jour"
             BackgroundColor="#1B1B2F">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="20" VerticalOptions="Center">

            <!-- Titre -->
            <Label Text="Trick du jour"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#E8E880"
                   HorizontalTextAlignment="Center" />

            <!-- Sous-titre -->
            <Label Text="Écoute ce que te dit Homer Simpson pour faire du ski comme un pro !"
                   FontSize="16"
                   TextColor="#CCCCCC"
                   HorizontalTextAlignment="Center" />

            <!-- GIF animé Homer skiing -->
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="#E8E880"
                    StrokeThickness="2"
                    Padding="0"
                    HorizontalOptions="Center">
                <Image Source="homer_skiing.gif"
                       IsAnimationPlaying="True"
                       HeightRequest="300"
                       Aspect="AspectFill" />
            </Border>

            <!-- Texte fun -->
            <Label Text="⚠️ Oublie pas de freiner !"
                   FontSize="14"
                   TextColor="#888888"
                   FontAttributes="Italic"
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0" />

            <!-- Bouton retour -->
            <Button Text="← Retour à l'accueil"
                    BackgroundColor="#E8E880"
                    TextColor="#1B1B2F"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="40,10"
                    Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

